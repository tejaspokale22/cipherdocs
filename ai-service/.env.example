# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Qdrant Configuration
QDRANT_URL=https://your-qdrant-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=cipherdocs_documents

# Nomic Configuration
NOMIC_API_KEY=your_nomic_api_key_here

# OpenAI (optional, for advanced features)
OPENAI_API_KEY=your_openai_api_key_here

# Node.js Backend URL (for inter-service communication)
NODE_BACKEND_URL=http://localhost:5000

# Service Authentication (shared secret between services)
SERVICE_API_KEY=your_secure_service_api_key_here

# Processing Configuration
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Trust Score Thresholds
TRUST_SCORE_HIGH_THRESHOLD=85
TRUST_SCORE_MEDIUM_THRESHOLD=60
